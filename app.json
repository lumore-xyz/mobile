{
  "expo": {
    "name": "lumore",
    "slug": "lumore",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "lumore",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/icon.png",
        "backgroundImage": "./assets/images/icon.png",
        "monochromeImage": "./assets/images/icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "xyz.lumore.www.twa"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-5845343690682759~9095410597",
          "iosAppId": "ca-app-pub-5845343690682759~5136193710"
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.681858960345-t8llre06pgn2pegq01kjgukhmuiu46kf"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "The app needs access to your photos",
          "cameraPermission": "The app needs access to your camera"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Lumore to use your location for better matches."
        }
      ],
      "@react-native-community/datetimepicker",
      "react-native-google-mobile-ads"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f463c566-8fe5-43e7-b8a4-542508f061ec"
      }
    },
    "owner": "lumorexyz"
  }
}
